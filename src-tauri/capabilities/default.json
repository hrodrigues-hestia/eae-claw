{
  "identifier": "eae-claw-default",
  "description": "Default permissions for Eae Claw",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "http://localhost:18789/*" },
        { "url": "http://127.0.0.1:18789/*" },
        { "url": "https://api.openai.com/*" }
      ]
    },
    "fs:default",
    {
      "identifier": "fs:allow-app-write",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "fs:allow-app-read",
      "allow": [{ "path": "$APPDATA/**" }]
    }
  ]
}
